# book-llm-wiki secrets
#
# Tier 1 (/ingest-book) and Tier 2 (/summarize-book) do not need secrets:
#   - ingest is pure Python, no API calls.
#   - analyze runs inside Claude Code and uses its own auth.
#
# /download-book needs all three variables below.

# Anna's Archive fast_download API key. Used by the book-downloader agent
# (via the annas-archive MCP server configured in .claude/settings.local.json)
# to pull direct EPUB download URLs. Required for /download-book.
annas_api_key=

# LibraryThing credentials. Used by book_summarizer.downloader.librarything
# (scrapling + Cloudflare bypass) to read/write the user's catalog. The
# script persists a browser session at ~/.lt-session after first login.
# Note: legacy colon-delimited format — the module parses `key:value` per
# line, not standard dotenv `key=value`. Do NOT switch to `=`.
username:
pass:
